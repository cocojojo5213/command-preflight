# Optional self-hosted knowledge service settings.
# This is the address inside the container. Compose publishes the host port on
# localhost by default; keep this at 0.0.0.0 unless you know the container
# networking behavior you want.
COMMAND_PREFLIGHT_BIND=0.0.0.0:8787
COMMAND_PREFLIGHT_DATA=/data/knowledge.json
# Host-side published address. Keep localhost by default; use a Tailnet IP for
# a private remote test, or put a TLS reverse proxy in front for public access.
COMMAND_PREFLIGHT_PUBLISHED_BIND=127.0.0.1:8787
# The default is a Docker named volume. Set this to ./data for a host bind
# mount, and make sure the directory is writable by UID 65532.
COMMAND_PREFLIGHT_DATA_VOLUME=command-preflight-data
# Public submissions enter a private moderation queue; they never update the
# knowledge API directly. Enabling the queue requires an admin token.
COMMAND_PREFLIGHT_ALLOW_REPORT=false
# Legacy operator token; COMMAND_PREFLIGHT_ADMIN_TOKEN takes precedence.
COMMAND_PREFLIGHT_REPORT_TOKEN=
COMMAND_PREFLIGHT_ADMIN_TOKEN=
# Optional for private deployments. Leave empty for an anonymous public queue
# and enforce request rate limits at the reverse proxy.
COMMAND_PREFLIGHT_REPORT_SUBMIT_TOKEN=
# Keep false to make forwarded Cloudflare/reverse-proxy admin requests fail.
COMMAND_PREFLIGHT_ALLOW_PROXIED_ADMIN=false
# Global limit; edge rate limiting is still recommended for public deployments.
COMMAND_PREFLIGHT_REPORTS_PER_MINUTE=60
COMMAND_PREFLIGHT_REPORT_RETENTION_DAYS=30

# Optional opt-in client lookup adapter. Empty means offline mode.
COMMAND_PREFLIGHT_KNOWLEDGE_URL=
# Reporting additionally requires COMMAND_PREFLIGHT_REPORTING=on. It never
# becomes active merely because a lookup URL is configured.
COMMAND_PREFLIGHT_REPORTING=off
COMMAND_PREFLIGHT_REPORT_URL=
COMMAND_PREFLIGHT_TELEMETRY=off
