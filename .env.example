# Optional self-hosted knowledge service settings.
# This is the address inside the container. Compose publishes the host port on
# localhost by default; keep this at 0.0.0.0 unless you know the container
# networking behavior you want.
COMMAND_PREFLIGHT_BIND=0.0.0.0:8787
COMMAND_PREFLIGHT_DATA=/data/knowledge.json
# The default is a Docker named volume. Set this to ./data for a host bind
# mount, and make sure the directory is writable by UID 65532.
COMMAND_PREFLIGHT_DATA_VOLUME=command-preflight-data
COMMAND_PREFLIGHT_ALLOW_REPORT=false
COMMAND_PREFLIGHT_REPORT_TOKEN=

# Optional opt-in client lookup adapter. Empty means offline mode.
COMMAND_PREFLIGHT_KNOWLEDGE_URL=
COMMAND_PREFLIGHT_TELEMETRY=off
